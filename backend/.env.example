# MongoDB connection string (from MongoDB Atlas)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/travel-planner

# JWT secret — use a long random string (e.g. openssl rand -base64 32)
JWT_SECRET=your_super_secret_jwt_key_here

# Stripe secret key (get from stripe.com/dashboard)
# Use sk_test_... for testing, sk_live_... for real payments
STRIPE_SECRET_KEY=sk_test_...

# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Server port (Render sets this automatically)
PORT=5001
